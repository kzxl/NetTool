<UserControl x:Class="NetTool.UI.Modules.WebSocket.WebSocketPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.ColumnDefinitions><ColumnDefinition Width="340" /><ColumnDefinition Width="12" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
        <StackPanel Grid.Column="0">
            <Border Style="{StaticResource CardBorder}">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionTitle}" Text="⚡ WEBSOCKET TESTER" />
                    <TextBlock Style="{StaticResource FieldLabel}" Text="WEBSOCKET URL" />
                    <TextBox Text="{Binding Url, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding IsNotRunning}" />
                    <TextBlock Style="{StaticResource FieldLabel}" Text="MESSAGE" />
                    <TextBox Text="{Binding Message, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding IsNotRunning}" />
                    <Grid Margin="0,12,0,0">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="12" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Style="{StaticResource StartButton}" Content="▶  TEST" Command="{Binding StartCommand}" />
                        <Button Grid.Column="2" Style="{StaticResource StopButton}" Content="■  STOP" Command="{Binding StopCommand}" />
                    </Grid>
                </StackPanel>
            </Border>
        </StackPanel>
        <Border Grid.Column="2" Style="{StaticResource CardBorder}">
            <DockPanel><TextBlock DockPanel.Dock="Top" Style="{StaticResource SectionTitle}" Text="📋 OUTPUT" />
                <ListBox Style="{StaticResource LogListBox}" ItemsSource="{Binding LogLines}" VirtualizingPanel.IsVirtualizing="True" BorderThickness="0">
                    <ListBox.ItemTemplate><DataTemplate><TextBlock Text="{Binding}" TextWrapping="Wrap" /></DataTemplate></ListBox.ItemTemplate></ListBox></DockPanel>
        </Border>
    </Grid>
</UserControl>

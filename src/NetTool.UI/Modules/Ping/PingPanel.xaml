<UserControl x:Class="NetTool.UI.Modules.Ping.PingPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="340" />
            <ColumnDefinition Width="12" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- LEFT: Config -->
        <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel>

                <!-- Host Config -->
                <Border Style="{StaticResource CardBorder}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionTitle}" Text="📡 PING CONFIG" />

                        <TextBlock Style="{StaticResource FieldLabel}" Text="HOST / IP" />
                        <TextBox Text="{Binding Host, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding IsNotRunning}" />

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Style="{StaticResource FieldLabel}" Text="COUNT" />
                                <TextBox Text="{Binding Count, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding IsNotRunning}" />
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Style="{StaticResource FieldLabel}" Text="INTERVAL (MS)" />
                                <TextBox Text="{Binding IntervalMs, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding IsNotRunning}" />
                            </StackPanel>
                        </Grid>

                        <TextBlock Style="{StaticResource FieldLabel}" Text="TIMEOUT (MS)" />
                        <TextBox Text="{Binding TimeoutMs, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding IsNotRunning}" />
                    </StackPanel>
                </Border>

                <!-- Controls -->
                <Border Style="{StaticResource CardBorder}">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" Style="{StaticResource StartButton}" Content="▶  PING" Command="{Binding StartCommand}" />
                            <Button Grid.Column="2" Style="{StaticResource StopButton}" Content="■  STOP" Command="{Binding StopCommand}" />
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Stats -->
                <Border Style="{StaticResource CardBorder}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionTitle}" Text="📊 STATISTICS" />

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                <TextBlock Style="{StaticResource FieldLabel}" Text="SENT" HorizontalAlignment="Center" FontSize="10" />
                                <TextBlock Text="{Binding Sent}" FontSize="18" FontWeight="Bold"
                                           Foreground="{StaticResource AccentBlueBrush}" HorizontalAlignment="Center" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                                <TextBlock Style="{StaticResource FieldLabel}" Text="OK" HorizontalAlignment="Center" FontSize="10" />
                                <TextBlock Text="{Binding Received}" FontSize="18" FontWeight="Bold"
                                           Foreground="{StaticResource AccentGreenBrush}" HorizontalAlignment="Center" />
                            </StackPanel>
                            <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                                <TextBlock Style="{StaticResource FieldLabel}" Text="FAIL" HorizontalAlignment="Center" FontSize="10" />
                                <TextBlock Text="{Binding Failed}" FontSize="18" FontWeight="Bold"
                                           Foreground="{StaticResource AccentRedBrush}" HorizontalAlignment="Center" />
                            </StackPanel>
                        </Grid>

                        <Grid Margin="0,12,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                <TextBlock Style="{StaticResource FieldLabel}" Text="AVG" HorizontalAlignment="Center" FontSize="10" />
                                <TextBlock Text="{Binding AvgLatency}" FontSize="14" FontWeight="Bold"
                                           Foreground="{StaticResource AccentCyanBrush}" HorizontalAlignment="Center" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                                <TextBlock Style="{StaticResource FieldLabel}" Text="MIN" HorizontalAlignment="Center" FontSize="10" />
                                <TextBlock Text="{Binding MinLatency}" FontSize="14" FontWeight="Bold"
                                           Foreground="{StaticResource AccentGreenBrush}" HorizontalAlignment="Center" />
                            </StackPanel>
                            <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                                <TextBlock Style="{StaticResource FieldLabel}" Text="MAX" HorizontalAlignment="Center" FontSize="10" />
                                <TextBlock Text="{Binding MaxLatency}" FontSize="14" FontWeight="Bold"
                                           Foreground="{StaticResource AccentOrangeBrush}" HorizontalAlignment="Center" />
                            </StackPanel>
                        </Grid>

                        <TextBlock Style="{StaticResource FieldLabel}" Text="RESOLVED IP" Margin="0,12,0,2" />
                        <TextBlock Text="{Binding ResolvedIp}" FontFamily="Cascadia Code, Consolas"
                                   Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" />
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- RIGHT: Chart + Log -->
        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="2*" />
                <RowDefinition Height="12" />
                <RowDefinition Height="*" MinHeight="120" />
            </Grid.RowDefinitions>

            <!-- Latency Chart -->
            <Border Grid.Row="0" Style="{StaticResource CardBorder}">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Style="{StaticResource SectionTitle}" Text="📈 LATENCY (MS)" />
                    <lvc:CartesianChart Series="{Binding LatencySeries}" AnimationsSpeed="00:00:00.200"
                                        ZoomMode="X" TooltipPosition="Top" />
                </DockPanel>
            </Border>

            <!-- Log -->
            <Border Grid.Row="2" Style="{StaticResource CardBorder}">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Style="{StaticResource SectionTitle}" Text="📋 LOG OUTPUT" />
                    <ListBox Style="{StaticResource LogListBox}" ItemsSource="{Binding LogLines}"
                             VirtualizingPanel.IsVirtualizing="True" VirtualizingPanel.VirtualizationMode="Recycling"
                             ScrollViewer.HorizontalScrollBarVisibility="Auto" ScrollViewer.VerticalScrollBarVisibility="Auto"
                             BorderThickness="0">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" TextWrapping="NoWrap" />
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>

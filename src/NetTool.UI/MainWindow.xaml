<Window x:Class="NetTool.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:NetTool.UI.ViewModels"
        Title="NetTool - Network Testing Suite"
        Width="1280" Height="800"
        MinWidth="1000" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BgDarkBrush}"
        Closing="Window_Closing">

    <Window.DataContext>
        <vm:ShellViewModel />
    </Window.DataContext>

    <DockPanel>
        <!-- Status Bar -->
        <Border DockPanel.Dock="Bottom"
                Background="{StaticResource BgMediumBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="12,6">
            <DockPanel>
                <Ellipse Width="6" Height="6" Fill="{StaticResource AccentGreenBrush}" Margin="0,0,8,0" VerticalAlignment="Center" />
                <TextBlock Text="{Binding SelectedTool.ViewModel.StatusText}"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="11.5" />
            </DockPanel>
        </Border>

        <!-- Title Bar -->
        <Border DockPanel.Dock="Top"
                Background="{StaticResource TitleBarGradient}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="16,12">
            <DockPanel>
                <TextBlock Text="🌌 NetTool"
                           FontSize="20" FontWeight="Bold"
                           Foreground="{StaticResource AccentBlueBrush}" />
                <TextBlock Text="·" FontSize="20" Margin="8,0"
                           Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Bottom" />
                <TextBlock Text="Network Testing Suite"
                           FontSize="12" VerticalAlignment="Bottom"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           Margin="0,0,0,3" FontWeight="Normal" />
            </DockPanel>
        </Border>

        <!-- Tab Control — populated by code-behind from ToolRegistry -->
        <TabControl x:Name="ToolTabs"
                    Background="Transparent"
                    BorderThickness="0"
                    Padding="0"
                    Margin="0" />
    </DockPanel>
</Window>

<Window x:Class="NetTool.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:NetTool.UI.ViewModels"
        Title="NetTool - Network Testing Suite"
        Width="1280" Height="800"
        MinWidth="1000" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BgDarkBrush}"
        Closing="Window_Closing">

    <Window.DataContext>
        <vm:ShellViewModel />
    </Window.DataContext>

    <DockPanel>
        <!-- Status Bar -->
        <Border DockPanel.Dock="Bottom"
                Background="{StaticResource BgMediumBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="12,6">
            <TextBlock Text="{Binding SelectedTool.ViewModel.StatusText}"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       FontSize="12" />
        </Border>

        <!-- Title Bar -->
        <Border DockPanel.Dock="Top"
                Background="{StaticResource BgMediumBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="16,12">
            <DockPanel>
                <TextBlock Text="🌌 NetTool"
                           FontSize="20" FontWeight="Bold"
                           Foreground="{StaticResource AccentBlueBrush}" />
                <TextBlock Text="Network Testing Suite"
                           FontSize="13" VerticalAlignment="Bottom"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           Margin="10,0,0,2" />
            </DockPanel>
        </Border>

        <!-- Tab Control — Dynamic from ToolRegistry -->
        <TabControl ItemsSource="{Binding Tools}"
                    SelectedItem="{Binding SelectedTool}"
                    Background="Transparent"
                    BorderThickness="0"
                    Margin="0">

            <TabControl.ItemTemplate>
                <DataTemplate>
                    <TextBlock Margin="8,4">
                        <Run Text="{Binding Icon, Mode=OneTime}" />
                        <Run Text="{Binding Name, Mode=OneTime}" />
                    </TextBlock>
                </DataTemplate>
            </TabControl.ItemTemplate>

            <TabControl.ContentTemplate>
                <DataTemplate>
                    <!-- Placeholder — actual content loaded via code-behind -->
                </DataTemplate>
            </TabControl.ContentTemplate>
        </TabControl>
    </DockPanel>
</Window>

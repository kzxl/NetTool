<Window x:Class="NetTool.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:NetTool.UI.Views"
        xmlns:vm="clr-namespace:NetTool.UI.ViewModels"
        Title="NetTool - API Performance Tester"
        Width="1280" Height="800"
        MinWidth="1000" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BgDarkBrush}"
        Closing="Window_Closing">

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <DockPanel>
        <!-- Status Bar -->
        <Border DockPanel.Dock="Bottom"
                Background="{StaticResource BgMediumBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="12,6">
            <TextBlock Text="{Binding StatusText}"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       FontSize="12" />
        </Border>

        <!-- Title Bar -->
        <Border DockPanel.Dock="Top"
                Background="{StaticResource BgMediumBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="16,12">
            <DockPanel>
                <TextBlock Text="🚀 NetTool"
                           FontSize="20" FontWeight="Bold"
                           Foreground="{StaticResource AccentBlueBrush}" />
                <TextBlock Text="API Performance Tester"
                           FontSize="13" VerticalAlignment="Bottom"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           Margin="10,0,0,2" />
            </DockPanel>
        </Border>

        <!-- Main Content -->
        <Grid Margin="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="340" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Left: Config -->
            <views:ConfigPanel Grid.Column="0" />

            <!-- Right: Charts + Log -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="3*" />
                    <RowDefinition Height="12" />
                    <RowDefinition Height="*" MinHeight="120" />
                </Grid.RowDefinitions>

                <views:ChartPanel Grid.Row="0" />
                <views:LogPanel Grid.Row="2" />
            </Grid>
        </Grid>
    </DockPanel>
</Window>
